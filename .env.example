# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prd_web_agent_dev

# NextAuth.js v5
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=change-me-in-production

# OAuth Provider (GitHub)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Redis (for Socket.io adapter)
REDIS_URL=redis://localhost:6379

# pi SDK
PI_SDK_API_KEY=""

# Encryption key for user API keys at rest (falls back to AUTH_SECRET if unset)
LLM_KEY_ENCRYPTION_SECRET=""

# EFS Mount Path (for agent sessions and repo clones)
EFS_MOUNT_PATH="/efs"
EFS_REPOS_DIR="${EFS_MOUNT_PATH}/repos"

# OpenTelemetry
OTEL_SERVICE_NAME="prd-web-agent"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# Logging
LOG_LEVEL="info"

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:18790
OPENCLAW_GATEWAY_TOKEN=change-me
OPENCLAW_INTERNAL_TOKEN=change-me-internal
# URL OpenClaw uses to call back into this app (use host.docker.internal when running via docker-compose)
APP_URL=http://host.docker.internal:3000
